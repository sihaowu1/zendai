{
  "name": "motionforge",
  "version": "0.1.0",
  "private": true,
  "description": "AI-powered, code-based 3D generation and video-editing system (Three.js/WebGL + Remotion)",
  "workspaces": [
    "shared",
    "server",
    "web",
    "remotion"
  ],
  "scripts": {
    "predev": "node scripts/free-ports.mjs",
    "dev": "concurrently -k -n server,web -c blue,magenta \"npm:dev:server\" \"npm:dev:web\"",
    "dev:server": "npm run dev --workspace server",
    "dev:web": "npm run dev --workspace web",
    "start:server": "npm run start --workspace server",
    "build:web": "npm run build --workspace web",
    "remotion:studio": "npm run studio --workspace remotion",
    "typecheck": "npm run typecheck --workspaces --if-present"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  },
  "dependencies": {
    "mongodb": "^7.5.0"
  }
}
