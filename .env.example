# OpenRouter API key used by the AI agents (server-side only).
# Without a key, the server falls back to a deterministic offline template generator
# so the app still runs end-to-end.
OPENROUTER_API_KEY=

# Auth0 (optional). When unset, the app runs fully anonymous — login is only
# needed for signed-in features like GitHub export.
# SPA origin must stay http://localhost:5173/ (see Allowed Callback / Logout / Web Origins).
# VITE_AUTH0_DOMAIN=dev-73ib7kyc8wkcyahg.us.auth0.com
# VITE_AUTH0_CLIENT_ID=sfEaa3oTqDnjaibEsoacCAC61wM5SaiG
# VITE_AUTH0_AUDIENCE=https://api.zendai.local
# AUTH0_DOMAIN=dev-73ib7kyc8wkcyahg.us.auth0.com
# AUTH0_AUDIENCE=https://api.zendai.local

# Auth0 Management API (Machine-to-Machine) — required for GitHub push.
# Create an M2M app authorized for the Auth0 Management API with scopes:
#   read:users, read:user_idp_tokens
# Also enable the GitHub social connection with `repo` scope and IdP token storage.
# AUTH0_MGMT_CLIENT_ID=
# AUTH0_MGMT_CLIENT_SECRET=
# MongoDB Atlas (optional). When unset, marketplace features return 503 but
# the rest of the app works normally.
# Get your connection string from https://cloud.mongodb.com → Connect → Drivers
# MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/motionforge?retryWrites=true&w=majority

# Optional overrides (defaults live in config/default.config.json)
# PORT=5174
# ANTHROPIC_MODEL=anthropic/claude-sonnet-4.5
# REMOTION_GL=angle
